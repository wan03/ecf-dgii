# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Certificado digital (password del .p12)
CERT_PASSWORD=your-certificate-password

# DGII API
DGII_URL_BASE=https://ecf.dgii.gov.do/testecf
DGII_CRON_SECRET=your-random-secret-for-cron

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (SMTP) — optional. If SMTP_HOST is set, the app sends notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFICATION_EMAIL=

# Test infrastructure
TEST_FAKE_DGII_PORT=8787
